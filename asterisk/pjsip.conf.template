; Generated at container start from EXTERNAL_IP (see entrypoint-wrap.sh).
; Phones on Wi-Fi need external_* set to your PC's LAN address.

[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0:5060
; Only treat Docker-internal subnets as local. Wi-Fi phones (172.17.x, 192.168.x)
; must be "remote" so Asterisk uses external_signaling_address in Contact.
; Broad 172.16.0.0/12 here caused Contact: sip:@172.19.0.2:5060 and 32s call drops.
local_net=127.0.0.0/8
local_net=172.19.0.0/16
@EXTERNAL_IP_LINES@

; -------------------- Extension 1000 --------------------

[1000]
type=endpoint
transport=transport-udp
context=internal
disallow=all
allow=ulaw
allow=alaw
auth=1000
aors=1000
direct_media=no
force_rport=yes
rewrite_contact=yes
rtp_symmetric=yes
ice_support=no
dtmf_mode=rfc4733
rtp_keepalive=5
@MEDIA_ADDRESS_LINE@

[1000]
type=auth
auth_type=userpass
username=1000
password=1000pass

[1000]
type=aor
max_contacts=3
remove_existing=no
qualify_frequency=30

