; =============================================================================
; DIDWW — inbound Voice-IN (regional SBCs) + outbound termination (out.didww.com)
; Docs: https://doc.didww.com/integrations/asterisk/
; =============================================================================

; Inbound PSTN — match DIDWW Voice-IN signaling IPs (no registration)
[didww_in]
type=endpoint
transport=transport-udp
context=from-trunk
disallow=all
allow=ulaw
allow=alaw
direct_media=no
force_rport=yes
rtp_symmetric=yes
trust_id_inbound=yes
timers=no
@MEDIA_ADDRESS_LINE@

[didww_in]
type=identify
endpoint=didww_in
match=46.19.209.14/32
match=46.19.210.14/32
match=46.19.212.14/32
match=46.19.213.14/32
match=46.19.214.14/32
match=46.19.215.14/32
match=185.238.172.4/32

; Outbound PSTN — IP whitelist + optional digest (username from DIDWW portal)
[didww_trunk_auth]
type=auth
auth_type=userpass
username=@DIDWW_USER@
password=@DIDWW_PASS@
realm=out.didww.com

[didww_trunk]
type=aor
contact=sip:out.didww.com
qualify_frequency=60

[didww_trunk]
type=endpoint
transport=transport-udp
disallow=all
allow=ulaw
allow=alaw
outbound_auth=didww_trunk_auth
aors=didww_trunk
; Per-call caller ID comes from CRM (agent org DID) via ARI — do not pin a single from_user here.
trust_id_outbound=yes
send_pai=yes
from_domain=@DIDWW_FROM_DOMAIN@
direct_media=no
force_rport=yes
rtp_symmetric=yes
rewrite_contact=yes
timers=no
@MEDIA_ADDRESS_LINE@
