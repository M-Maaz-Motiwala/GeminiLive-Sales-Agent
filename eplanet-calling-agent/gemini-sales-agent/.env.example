# =============================================================================
# eplanet platform — local dev ONLY (optional)
#
# For the unified astrersik Docker stack, use the ROOT env files instead:
#   cp ../../.env.example ../../.env
#   edit ../../.env
#   ./start.sh up -d --build
# =============================================================================

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database (local dev; Docker stack uses postgres service) ---
DATABASE_URL=postgresql+asyncpg://aura:aura_secret@localhost:5432/aura_db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change_me_to_a_long_random_secret

# --- Pinecone RAG (same index name as root stack) ---
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=aura-knowledge
PINECONE_ENVIRONMENT=us-east-1

# --- Bridge internal API (must match root .env) ---
BRIDGE_INTERNAL_TOKEN=change-me-bridge-token

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@aura.ai
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# --- Frontend local dev (npm run dev) ---
VITE_API_URL=http://localhost:8000

# NOTE: SIP/ARI/RTP telephony is owned by astrersik bridge — configure in root .env
