# --- Gemini Live ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyDQW1jz-ARU1qMMxVs_oW_7pPPStydi1L8
# Same model + voice as the React reference (gemini-sales-agent).
# That app sustains long multi-turn conversations with this exact
# combo, so the bridge now matches it byte-for-byte.
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Zephyr

# --- Asterisk ARI ---
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# --- RTP bridge ---
# Asterisk and bridge share the docker "voip" network; ExternalMedia uses
# bridge:40000 (no host IP needed for AI leg).
RTP_PORT=40000

# --- WebRTC audio processing (AEC + NS + AGC) on inbound mic audio.
# Google's official telephony reference does NOT use any APM: real
# PSTN/Twilio audio is already clean (no acoustic loop because the
# phone speaker doesn't bleed into its own mic). APM is only useful
# for laptop self-test (Zoiper on speakers). Default OFF; turn on
# Default OFF for real phone calls — server AEC can mis-cancel user speech
# after turn 1 (turn 2+ goes silent). Use APM_ENABLED=0 only for laptop
# Zoiper-on-speakers testing with headphones recommended.
APM_ENABLED=0
# AEC defaults ON because phone audio has no echo cancellation. If
# multi-turn breaks (Gemini doesn't respond after first turn_complete),
# set APM_AEC=0 to check whether AEC is mis-classifying user speech
# as residual AI echo.
APM_AEC=1
# NS defaults to mild (level 1 = 12 dB attenuation). Level 2/3 can
# aggressively gate out telephony speech too.
APM_NS=1
APM_NS_LEVEL=1
# AGC defaults OFF: APM's AGC2 can ramp gain down when it sees AI
# echo through speakers, then never ramp back up for user speech.
# INBOUND_GAIN below gives a static lift instead.
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150
# Static pre-APM gain. With AGC off this is the only lift on the
# inbound path.
INBOUND_GAIN=2.0

TTS_GATING=0
# AEC convergence window: gate inbound audio for the first N ms of
# each AI utterance. After this AEC handles echo cancellation and
# Gemini's interruption fires normally if the user talks over the AI.
TTS_GATE_TAIL_MS=200
# Mute mic-to-Gemini while AI plays — OFF (React sends mic always).
ECHO_GATE_SEC=0.5

# --- Gemini Live transport ---
# 256 ms matches the React reference EXACTLY: it uses a 4096-sample
# ScriptProcessorNode buffer at 16 kHz, which fires onaudioprocess
# every 256 ms. That's ~4 messages/sec to the WebSocket; the model's
# own VAD takes care of turn boundaries inside the buffer. Higher
# rates (we used to send at 50 Hz) appear to confuse the model's
# state machine in multi-turn conversations.
GEMINI_CHUNK_MS=256

# Auto-greeting kicks the model to speak first via realtime_input.
# Defaults to OFF because:
#   1) The React reference doesn't auto-greet and works smoothly.
#   2) Even the "correct" realtime_input(text=...) path appears to
#      put preview models into a state where they freeze after the
#      first turn_complete.
# When OFF, the user speaks first ("hello") and the model responds
# normally. Set this to a string to re-enable.
AUTO_GREETING=

RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
