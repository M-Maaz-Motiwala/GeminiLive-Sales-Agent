# =============================================================================
# astrersik unified stack — copy to .env and fill in secrets
#
#   cp .env.example .env
#
# Used by: platform, celery_worker, platform_init, bridge (docker-compose)
# Auto-generated (do not edit): .host.env (EXTERNAL_IP — written by ./start.sh)
# =============================================================================

# =============================================================================
# GEMINI — voice AI + RAG embeddings
# =============================================================================
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Live model + voice (per-agent overrides in Admin → Agents)
GEMINI_MODEL=gemini-3.1-flash-live-preview
# Post-call summaries and structured outputs (separate from live voice model)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VOICE=Zephyr

# =============================================================================
# PLATFORM — PostgreSQL, Redis, JWT, admin bootstrap
# =============================================================================
DATABASE_URL=postgresql+asyncpg://aura:aura_secret@postgres:5432/aura_db
REDIS_URL=redis://redis:6379/0

# Use a long random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret

ADMIN_EMAIL=admin@aura.ai
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# =============================================================================
# PINECONE — knowledge base / RAG (search_knowledge_base tool)
# =============================================================================
# Get key: https://app.pinecone.io/ → API Keys → Create key
# Index aura-knowledge is auto-created on first bootstrap if missing.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aura-knowledge
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# BRIDGE ↔ PLATFORM — internal API (must match on both services)
# =============================================================================
BRIDGE_INTERNAL_TOKEN=change-me-bridge-token
PLATFORM_URL=http://platform:8001

# =============================================================================
# ASTERISK ARI — bridge connects here (must match asterisk/ari.conf)
# =============================================================================
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# =============================================================================
# SIP / RTP — Zoiper on same Wi-Fi as this PC (see Dashboard for live values)
# =============================================================================
# EXTERNAL_IP=auto     → detect LAN IP (local lab)
# EXTERNAL_IP=windows  → WSL: Windows Wi-Fi/LAN IP
# Production VPS — public IP whitelisted at DIDWW: 38.86.174.122
EXTERNAL_IP=windows
SIP_PORT=5060
SIP_USER=1000
SIP_PASS=1000pass
SIP_USER_1001=1001
SIP_PASS_1001=1001pass
SIP_CODEC=PCMU

# DIDWW outbound trunk — get password from DIDWW portal → Outbound Trunks → key icon
DIDWW_SIP_USER=86vbvm130t
DIDWW_SIP_SECRET=4uhqz3e48y
DIDWW_FROM_DOMAIN=out.didww.com
# Caller ID DID sent in From header (digits only; no +)
DIDWW_CALLER_ID=12107297915

# Outbound: lab (PJSIP/100x) | trunk (PJSIP/+E164@didww_trunk)
OUTBOUND_MODE=trunk
OUTBOUND_TRUNK_NAME=didww_trunk
OUTBOUND_TRUNK_CALLER_ID=
OUTBOUND_DEFAULT_COUNTRY_CODE=1

# Outbound call window — disabled for now (24/7 dialing)
OUTBOUND_CALL_WINDOW_ENABLED=false

RTP_PORT=40000
EXTERNAL_MEDIA_HOST=bridge

# Only if Asterisk uses host networking / loopback RTP (optional)
# ASTERISK_RTP_HOST=host.docker.internal

# =============================================================================
# AUDIO / TELEPHONY TUNING — gemini_bridge
# =============================================================================
# WebRTC APM (echo cancel, noise suppress). Default OFF for real SIP phones.
APM_ENABLED=0
APM_AEC=1
APM_NS=1
APM_NS_LEVEL=1
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150

# Static pre-APM mic gain
INBOUND_GAIN=2.0

# TTS / echo gating (usually OFF for SIP)
TTS_GATING=0
TTS_GATE_TAIL_MS=200
ECHO_GATE_SEC=0.5

# Gemini Live audio chunk size (ms) — 256 matches reference app
GEMINI_CHUNK_MS=256

# Empty = use built-in default greeting (agent speaks first on connect)
AUTO_GREETING="Hello! there,"

# Call setup timing
RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
SEND_LOOP_HUNG_SEC=3.0
OUTBOUND_RING_WHILE_CONNECTING=true

END_CALL_MIN_WAIT_SEC=0.3
END_CALL_PLAYBACK_GRACE_SEC=1.0
END_CALL_MAX_WAIT_SEC=7

# =============================================================================
# FRONTEND — local npm dev only (Docker nginx proxies /api; leave empty in prod)
# =============================================================================
# VITE_API_URL=http://localhost:8000

# =============================================================================
# GOOGLE OAUTH & GOOGLE CALENDAR INTEGRATION
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
CALENDAR_REDIRECT_URI=http://localhost:8000/api/calendar/callback
# Encrypts Google Calendar tokens in DB (Fernet key)
CALENDAR_ENCRYPTION_KEY=t-GbX62dx4rM_hW2Gg8m1r51c_Jm2jF7Z32uB8Z0d5A=

