# --- Gemini Live ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE
# AI Studio v1beta Live model. The Vertex AI telephony reference
# uses `gemini-live-2.5-flash-native-audio`, which is not exposed
# on v1beta. The closest AI Studio analog is the dec-2025 native
# audio preview below.
# Fallback if multi-turn breaks: gemini-3.1-flash-live-preview
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE=Achird

# --- Asterisk ARI ---
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# --- RTP bridge ---
# UDP port the FastAPI bridge listens on for ExternalMedia RTP from Asterisk.
# Asterisk reaches the bridge via DNS name "bridge" on the docker network.
RTP_PORT=40000

# --- WebRTC audio processing (AEC + NS + AGC) on inbound mic audio.
# Google's official telephony reference does NOT use any APM: real
# PSTN/Twilio audio is already clean (no acoustic loop because the
# phone speaker doesn't bleed into its own mic). APM is only useful
# for laptop self-test (Zoiper on speakers without headphones).
# Default OFF; turn on only if testing without headphones. ---
APM_ENABLED=0
APM_AEC=1
APM_NS=1
APM_NS_LEVEL=1
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150
INBOUND_GAIN=2.0

# --- TTS gating (only used when APM is on; safety net for self-test
# echo during AEC convergence) ---
TTS_GATING=1
TTS_GATE_TAIL_MS=200

# --- Gemini Live transport ---
# 20 ms (50 Hz) matches Google's telephony reference exactly: each
# inbound 20 ms ulaw frame from Asterisk is upsampled and sent
# straight to Gemini. The 5 s silent heartbeat keeps the WebSocket
# alive between user utterances.
GEMINI_CHUNK_MS=20
SEND_LOOP_HUNG_SEC=3.0

# --- Call UX ---
# Empty string => user speaks first (matches Google's reference and
# the React example; eliminates a class of "model freezes after
# first turn" bugs). Set to a sentence to make the AI greet first.
AUTO_GREETING=
RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
