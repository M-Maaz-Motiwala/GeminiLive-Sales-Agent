# =============================================================================
# astrersik unified stack — copy to .env and fill in secrets
#
#   cp .env.example .env
#
# Used by: platform, celery_worker, platform_init, bridge (docker-compose)
# Auto-generated (do not edit): .host.env (EXTERNAL_IP — written by ./start.sh)
# =============================================================================

# =============================================================================
# GEMINI — voice AI + RAG embeddings
# =============================================================================
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Live model + voice (per-agent overrides in Admin → Agents)
GEMINI_MODEL=gemini-3.1-flash-live-preview
# Post-call summaries and structured outputs (separate from live voice model)
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VOICE=Zephyr

# Token estimation for session pricing (Live API — adjust to your model sheet)
GEMINI_AUDIO_INPUT_TPS=25
GEMINI_AUDIO_OUTPUT_TPS=25
GEMINI_TEXT_CHARS_PER_TOKEN=4
# USD per 1M tokens (defaults match Gemini Live audio pricing)
GEMINI_PRICE_AUDIO_INPUT_PER_1M=3.0
GEMINI_PRICE_AUDIO_OUTPUT_PER_1M=12.0
GEMINI_PRICE_TEXT_INPUT_PER_1M=0.5
GEMINI_PRICE_TEXT_OUTPUT_PER_1M=2.0

# =============================================================================
# PLATFORM — PostgreSQL, Redis, JWT, admin bootstrap
# =============================================================================
DATABASE_URL=postgresql+asyncpg://aura:aura_secret@postgres:5432/aura_db
REDIS_URL=redis://redis:6379/0

# Use a long random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret

ADMIN_EMAIL=admin@aura.ai
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# =============================================================================
# PINECONE — knowledge base / RAG (search_knowledge_base tool)
# =============================================================================
# Get key: https://app.pinecone.io/ → API Keys → Create key
# Index aura-knowledge is auto-created on first bootstrap if missing.
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=aura-knowledge
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# BRIDGE ↔ PLATFORM — internal API (must match on both services)
# =============================================================================
BRIDGE_INTERNAL_TOKEN=change-me-bridge-token
PLATFORM_URL=http://platform:8000
# Platform → bridge HTTP (Docker: http://bridge:8000)
BRIDGE_URL=http://bridge:8000

# Outbound: lab (PJSIP/100x) | trunk (PJSIP/+E164@trunk) when SIP provider ready
OUTBOUND_MODE=lab
OUTBOUND_LAB_ENDPOINT=PJSIP/1001
OUTBOUND_DEFAULT_CALLER_ID=1000
OUTBOUND_DEFAULT_COUNTRY_CODE=1
# Trunk mode (Phase 2b — configure Asterisk trunk peer first)
OUTBOUND_TRUNK_NAME=
OUTBOUND_TRUNK_CALLER_ID=
MAX_CONCURRENT_OUTBOUND=5

# DIDWW-specific trunk headers (only used when OUTBOUND_TRUNK_NAME=didww_trunk)
# DIDWW auth username/password from portal:
# DIDWW_SIP_USER=
# DIDWW_SIP_SECRET=
# DIDWW expects numeric caller in From user (no '+'):
# DIDWW_CALLER_ID=12107297915
# DIDWW signaling domain:
# DIDWW_FROM_DOMAIN=out.didww.com

# Bridge concurrent calls (per-call RTP ports 40000–40049)
MAX_CONCURRENT_CALLS=5
RTP_PORT_BASE=40000
RTP_PORT_COUNT=50

# Outbound call window (set OUTBOUND_CALL_WINDOW_ENABLED=true to enforce hours)
OUTBOUND_CALL_WINDOW_ENABLED=false
OUTBOUND_CALL_TIMEZONE=UTC
OUTBOUND_CALL_HOUR_START=0
OUTBOUND_CALL_HOUR_END=24

# Lab prospect phones 1001–1010 (outbound dial targets; default pass = {ext}pass)
SIP_USER_1001=1001
SIP_PASS_1001=1001pass
SIP_USER_1002=1002
SIP_PASS_1002=1002pass
SIP_USER_1003=1003
SIP_PASS_1003=1003pass
SIP_USER_1004=1004
SIP_PASS_1004=1004pass
SIP_USER_1005=1005
SIP_PASS_1005=1005pass
SIP_USER_1006=1006
SIP_PASS_1006=1006pass
SIP_USER_1007=1007
SIP_PASS_1007=1007pass
SIP_USER_1008=1008
SIP_PASS_1008=1008pass
SIP_USER_1009=1009
SIP_PASS_1009=1009pass
SIP_USER_1010=1010
SIP_PASS_1010=1010pass

# =============================================================================
# ASTERISK ARI — bridge connects here (must match asterisk/ari.conf)
# =============================================================================
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# =============================================================================
# SIP / RTP — Zoiper on same Wi-Fi as this PC (see Dashboard for live values)
# =============================================================================
# EXTERNAL_IP=auto     → detect IP every ./start.sh (on WSL: uses Windows Wi-Fi/LAN IP)
# EXTERNAL_IP=windows  → WSL only: force Windows LAN IP via powershell
# EXTERNAL_IP=192.168.1.50 → fixed override (run 'ipconfig' on Windows for Wi-Fi IPv4)
# Do NOT use 127.0.0.1 — Zoiper may register but calls drop after ~30 seconds.
EXTERNAL_IP=auto
SIP_PORT=5060
SIP_USER=1000
SIP_PASS=1000pass
SIP_CODEC=PCMU

RTP_PORT=40000
EXTERNAL_MEDIA_HOST=bridge

# Only if Asterisk uses host networking / loopback RTP (optional)
# ASTERISK_RTP_HOST=host.docker.internal

# =============================================================================
# AUDIO / TELEPHONY TUNING — gemini_bridge
# =============================================================================
# WebRTC APM (echo cancel, noise suppress). Default OFF for real SIP phones.
APM_ENABLED=0
APM_AEC=1
APM_NS=1
APM_NS_LEVEL=1
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150

# Static pre-APM mic gain
INBOUND_GAIN=2.0

# TTS / echo gating (usually OFF for SIP)
TTS_GATING=0
TTS_GATE_TAIL_MS=200
ECHO_GATE_SEC=0.5

# Gemini Live audio chunk size (ms) — 256 matches reference app
GEMINI_CHUNK_MS=256

# Empty = use built-in default greeting (agent speaks first on connect)
AUTO_GREETING=

# Call setup timing (RING_MIN_SEC + ARI ringback = inbound only; outbound skips both)
RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
SEND_LOOP_HUNG_SEC=3.0

# =============================================================================
# FRONTEND — local npm dev only (Docker nginx proxies /api; leave empty in prod)
# =============================================================================
# VITE_API_URL=http://localhost:8000
