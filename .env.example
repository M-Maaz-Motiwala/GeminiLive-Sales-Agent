# =============================================================================
# astrersik unified stack — copy to .env and fill in secrets
#
#   cp .env.example .env
#
# Used by: platform, celery_worker, platform_init, bridge (docker-compose)
# Auto-generated (do not edit): .host.env (EXTERNAL_IP — written by ./start.sh)
# =============================================================================

# =============================================================================
# GEMINI — voice AI + RAG embeddings
# =============================================================================
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Live model + voice (per-agent overrides in Admin → Agents)
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Zephyr

# =============================================================================
# PLATFORM — PostgreSQL, Redis, JWT, admin bootstrap
# =============================================================================
DATABASE_URL=postgresql+asyncpg://aura:aura_secret@postgres:5432/aura_db
REDIS_URL=redis://redis:6379/0

# Use a long random string in production
JWT_SECRET_KEY=change_me_to_a_long_random_secret

ADMIN_EMAIL=admin@aura.ai
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# =============================================================================
# PINECONE — knowledge base / RAG (search_knowledge_base tool)
# =============================================================================
# Get key: https://app.pinecone.io/ → API Keys → Create key
# Index aura-knowledge is auto-created on first bootstrap if missing.
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=aura-knowledge
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# BRIDGE ↔ PLATFORM — internal API (must match on both services)
# =============================================================================
BRIDGE_INTERNAL_TOKEN=change-me-bridge-token
PLATFORM_URL=http://platform:8000

# =============================================================================
# ASTERISK ARI — bridge connects here (must match asterisk/ari.conf)
# =============================================================================
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# =============================================================================
# SIP / RTP — ExternalMedia → bridge
# =============================================================================
RTP_PORT=40000
EXTERNAL_MEDIA_HOST=bridge

# Only if Asterisk uses host networking / loopback RTP (optional)
# ASTERISK_RTP_HOST=host.docker.internal

# =============================================================================
# AUDIO / TELEPHONY TUNING — gemini_bridge
# =============================================================================
# WebRTC APM (echo cancel, noise suppress). Default OFF for real SIP phones.
APM_ENABLED=0
APM_AEC=1
APM_NS=1
APM_NS_LEVEL=1
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150

# Static pre-APM mic gain
INBOUND_GAIN=2.0

# TTS / echo gating (usually OFF for SIP)
TTS_GATING=0
TTS_GATE_TAIL_MS=200
ECHO_GATE_SEC=0.5

# Gemini Live audio chunk size (ms) — 256 matches reference app
GEMINI_CHUNK_MS=256

# Empty = use built-in default greeting (agent speaks first on connect)
AUTO_GREETING=

# Call setup timing
RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
SEND_LOOP_HUNG_SEC=3.0

# =============================================================================
# FRONTEND — local npm dev only (Docker nginx proxies /api; leave empty in prod)
# =============================================================================
# VITE_API_URL=http://localhost:8000
