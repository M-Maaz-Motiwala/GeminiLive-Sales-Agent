PLATFORM_URL=http://platform:8000
BRIDGE_URL=http://bridge:8000

# Asterisk / network
EXTERNAL_IP=172.16.103.164
STAGING_SIP_PORT=5061
ASTERISK_RTP_START=10060
ASTERISK_RTP_END=10110
ARI_USER=gemini
ARI_PASS=gemini123
ARI_APP=gemini-agent
ARI_HOST=asterisk
ARI_PORT=8088

# Lab SIP users
SIP_USER=1000
SIP_PASS=1000pass
SIP_USER_1001=1001
SIP_PASS_1001=1001pass
SIP_CODEC=PCMU

# Staging trunk / DID.
# Prefer a separate staging DID routed to SERVER_IP:5061.
# Fill these only after a staging trunk or staging DID route exists.
# DIDWW_SIP_USER=
# DIDWW_SIP_SECRET=
DIDWW_FROM_DOMAIN=out.didww.com
# DIDWW_CALLER_ID=
OUTBOUND_MODE=trunk
OUTBOUND_TRUNK_NAME=
OUTBOUND_TRUNK_CALLER_ID=
OUTBOUND_DEFAULT_COUNTRY_CODE=1

# Bridge media
RTP_PORT=40000
EXTERNAL_MEDIA_HOST=bridge
MAX_CONCURRENT_CALLS=5
RTP_PORT_BASE=40000
RTP_PORT_COUNT=50

# Call behavior
OUTBOUND_CALL_WINDOW_ENABLED=false
APM_ENABLED=0
APM_AEC=1
APM_NS=1
APM_NS_LEVEL=1
APM_AGC=0
APM_AGC_MAX_GAIN_DB=20
APM_HP=1
APM_STREAM_DELAY_MS=150
INBOUND_GAIN=2.0
TTS_GATING=0
TTS_GATE_TAIL_MS=200
ECHO_GATE_SEC=0.5
GEMINI_CHUNK_MS=256
AUTO_GREETING="Hello! this is the staging line."
RING_MIN_SEC=3
GEMINI_READY_TIMEOUT_SEC=20
SEND_LOOP_HUNG_SEC=3.0
OUTBOUND_RING_WHILE_CONNECTING=true
END_CALL_MIN_WAIT_SEC=0.3
END_CALL_PLAYBACK_GRACE_SEC=1.0
END_CALL_MAX_WAIT_SEC=7
